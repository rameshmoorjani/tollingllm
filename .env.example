# AWS Bedrock Configuration (REQUIRED for AWS deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Bedrock Model Selection (Optional - defaults to Llama 3.1 8B)
# Options:
#   - meta.llama3-8b-instruct-v1:0 (RECOMMENDED - fast, cost-effective)
#   - meta.llama3-70b-instruct-v1:0 (larger, more capable)
#   - mistral.mistral-7b-instruct-v0:2 (fast, multilingual)
BEDROCK_MODEL=meta.llama3-8b-instruct-v1:0

# Local Ollama Configuration (For local development, REMOVE if using AWS)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=mistral

# Backend Configuration
NODE_ENV=development
API_PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB Configuration
MONGODB_URI=mongodb://admin:password@mongodb:27017/tolling_db?authSource=admin
MONGODB_DATABASE=tolling_db
MONGODB_COLLECTION=transactions
