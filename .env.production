# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update values

# Node Environment
NODE_ENV=production
LOG_LEVEL=info

# ============================================
# MONGODB CONFIGURATION
# ============================================
# For MongoDB Atlas (Cloud): Use full connection string
# For local MongoDB: mongodb://admin:password@mongodb:27017/tolling_db?authSource=admin
MONGODB_URI=mongodb://admin:YOUR_SECURE_PASSWORD@mongodb:27017/tolling_db?authSource=admin
MONGODB_DATABASE=tolling_db
MONGODB_COLLECTION=transactions

# MongoDB Root Credentials (only for local setup)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=YOUR_SECURE_PASSWORD

# ============================================
# OLLAMA LLM CONFIGURATION
# ============================================
# Ollama Host (for remote Ollama server)
OLLAMA_HOST=http://ollama:11434
# OR use local machine Ollama: http://host.docker.internal:11434

# Available models (download with: ollama pull <model>)
# - mistral: Best balance of speed/quality (7B, 4.1GB)
# - neural-chat: Good for conversations (7B, 4.07GB)
# - llama2: More capable (7B, 3.8GB)
# - dolphin-mixtral: Larger capability (8x7B, 47GB)
OLLAMA_MODEL=mistral

# ============================================
# API SERVER CONFIGURATION
# ============================================
API_PORT=5000
API_HOST=0.0.0.0

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.com

# ============================================
# OPTIONAL: LLM ALTERNATIVES
# (Only set these if NOT using Ollama)
# ============================================

# HuggingFace API (requires valid token)
# Get token from: https://huggingface.co/settings/tokens
# With "read" and "repo.content.read" permissions
HF_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# ============================================
# DEPLOYMENT PLATFORM SPECIFIC
# ============================================
# For Railway.app deployment
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_SERVICE_NAME=tolling-llm

# For other platforms
# APP_ENVIRONMENT=production
